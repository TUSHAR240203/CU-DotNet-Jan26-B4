@model IEnumerable<TravelDestinationFrontend.Models.DestinationViewModel>

@{
    ViewData["Title"] = "Travel Destinations";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    :root {
        --bg-main: linear-gradient(135deg, #f8fbff 0%, #eef4ff 100%);
        --card-bg: rgba(255, 255, 255, 0.75);
        --card-border: rgba(255, 255, 255, 0.35);
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 20px 40px rgba(59, 130, 246, 0.18);
        --primary-grad: linear-gradient(135deg, #2563eb, #4f46e5);
        --accent-grad: linear-gradient(135deg, #06b6d4, #3b82f6);
        --badge-grad: linear-gradient(135deg, #f59e0b, #f97316);
    }

    body {
        background: var(--bg-main);
        color: var(--text-main);
        transition: background 0.35s ease, color 0.35s ease;
    }

        body.dark-mode {
            --bg-main: linear-gradient(135deg, #0f172a 0%, #111827 50%, #1e293b 100%);
            --card-bg: rgba(17, 24, 39, 0.72);
            --card-border: rgba(255, 255, 255, 0.08);
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.35);
            --shadow-hover: 0 22px 45px rgba(37, 99, 235, 0.25);
        }
        body.pink-mode {
    --bg-main: linear-gradient(135deg, #fff1f7 0%, #ffe4ee 50%, #ffd6e7 100%);
    --card-bg: rgba(255, 255, 255, 0.72);
    --card-border: rgba(255, 192, 203, 0.35);
    --text-main: #5b2146;
    --text-muted: #9a5f7d;
    --shadow-soft: 0 10px 30px rgba(236, 72, 153, 0.12);
    --shadow-hover: 0 20px 40px rgba(236, 72, 153, 0.20);
    --primary-grad: linear-gradient(135deg, #f9a8d4, #f472b6);
    --accent-grad: linear-gradient(135deg, #fbcfe8, #f9a8d4);
    --input-bg: rgba(255,255,255,0.75);
}
    .travel-page {
        min-height: 100vh;
    }

    .hero-panel {
        position: relative;
        overflow: hidden;
        background: var(--primary-grad);
        border-radius: 28px;
        padding: 2rem;
        color: white;
        box-shadow: var(--shadow-soft);
    }

        .hero-panel::before,
        .hero-panel::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
            z-index: 0;
        }

        .hero-panel::before {
            width: 220px;
            height: 220px;
            top: -70px;
            right: -60px;
        }

        .hero-panel::after {
            width: 140px;
            height: 140px;
            bottom: -40px;
            left: 35%;
        }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.4rem;
    }

    .hero-subtitle {
        margin-bottom: 0;
        color: rgba(255,255,255,0.88);
    }

    .top-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn-modern {
        border: none;
        border-radius: 14px;
        padding: 0.8rem 1.15rem;
        font-weight: 600;
        transition: all 0.25s ease;
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
    }

    .btn-add {
        background: white;
        color: #1d4ed8;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.12);
            color: #1e40af;
        }

    .btn-theme {
        background: rgba(255,255,255,0.15);
        color: white;
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.2);
    }

        .btn-theme:hover {
            background: rgba(255,255,255,0.22);
            transform: translateY(-2px);
            color: white;
        }

    .stats-strip {
        margin-top: 1.5rem;
    }

    .mini-stat {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 1rem 1.2rem;
        box-shadow: var(--shadow-soft);
        height: 100%;
    }

        .mini-stat .label {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .mini-stat .value {
            font-size: 1.5rem;
            font-weight: 800;
            margin-top: 0.15rem;
        }

    .destination-card {
        position: relative;
        overflow: hidden;
        background: var(--card-bg);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        box-shadow: var(--shadow-soft);
        transition: all 0.3s ease;
        height: 100%;
    }

        .destination-card:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: var(--shadow-hover);
        }

        .destination-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto 0;
            height: 6px;
            background: var(--accent-grad);
        }

    .card-top {
        padding: 1.25rem 1.25rem 0.8rem 1.25rem;
    }

    .destination-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.1);
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 0.9rem;
    }

    body.dark-mode .destination-badge {
        background: rgba(96, 165, 250, 0.16);
        color: #93c5fd;
    }

    .destination-title {
        font-size: 1.3rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
        line-height: 1.2;
    }

    .destination-country {
        color: var(--text-muted);
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 1rem;
    }

    .destination-description {
        color: var(--text-muted);
        font-size: 0.94rem;
        line-height: 1.7;
        min-height: 72px;
        margin-bottom: 1rem;
    }

    .info-panel {
        margin: 0 1.25rem 1rem 1.25rem;
        padding: 1rem;
        border-radius: 18px;
        background: rgba(255,255,255,0.35);
        border: 1px solid rgba(255,255,255,0.2);
    }

    body.dark-mode .info-panel {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .rating-row,
    .date-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .rating-label,
    .date-label {
        color: var(--text-muted);
        font-size: 0.86rem;
        font-weight: 600;
    }

    .stars {
        display: flex;
        align-items: center;
        gap: 0.2rem;
        flex-wrap: wrap;
    }

        .stars i {
            color: #fbbf24;
            font-size: 0.95rem;
        }

    .rating-number {
        margin-left: 0.35rem;
        font-weight: 700;
        color: var(--text-main);
    }

    .date-value {
        font-weight: 700;
        color: var(--text-main);
        font-size: 0.9rem;
    }

    .card-actions {
        display: flex;
        gap: 0.6rem;
        padding: 0 1.25rem 1.25rem 1.25rem;
        margin-top: auto;
    }

    .action-btn {
        flex: 1;
        border-radius: 14px;
        padding: 0.72rem 0.9rem;
        font-weight: 700;
        border: none;
        transition: all 0.25s ease;
        text-decoration: none;
        text-align: center;
    }

    .action-details {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
    }

    .action-edit {
        background: linear-gradient(135deg, #f59e0b, #ea580c);
        color: white;
    }

    .action-delete {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
    }

    .action-btn:hover {
        transform: translateY(-2px);
        filter: brightness(1.05);
        color: white;
    }

    .empty-state {
        background: var(--card-bg);
        backdrop-filter: blur(16px);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        box-shadow: var(--shadow-soft);
        padding: 4rem 1.5rem;
        text-align: center;
    }

    .empty-icon {
        font-size: 3.5rem;
        margin-bottom: 1rem;
        display: inline-block;
    }

    .section-title {
        font-weight: 800;
        margin-bottom: 1rem;
    }

    @@media (max-width: 768px) {
        .hero-panel {
            padding: 1.5rem;
        }

        .hero-title {
            font-size: 1.55rem;
        }

        .top-actions {
            margin-top: 1rem;
        }
    }
</style>

<div class="container py-4 travel-page">

    @{
        var destinationCount = Model?.Count() ?? 0;
    }

    <div class="hero-panel mb-4">
        <div class="hero-content">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="hero-title">🌍 Travel Destinations</div>
                    <p class="hero-subtitle">
                        Discover, organize, and manage your world-class travel experiences in a modern dashboard.
                    </p>
                </div>

                <div class="top-actions">
                    <button id="themeToggle" type="button" class="btn-modern btn-theme">
                        <i class="bi bi-moon-stars-fill me-2"></i>Theme
                    </button>

                    <a asp-action="Create" class="btn-modern btn-add">
                        <i class="bi bi-plus-circle-fill me-2"></i>Add Destination
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 stats-strip mb-4">
        <div class="col-md-4">
            <div class="mini-stat">
                <div class="label">Total Destinations</div>
                <div class="value">@destinationCount</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mini-stat">
                <div class="label">Travel Collection</div>
                <div class="value">Premium</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="mini-stat">
                <div class="label">Interface Mode</div>
                <div class="value" id="themeModeText">Light</div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">✈️</div>
            <h3 class="fw-bold mb-2">No destinations added yet</h3>
            <p class="text-muted mb-4">Start building your premium travel collection with your first destination.</p>
            <a asp-action="Create" class="btn-modern btn-add">
                <i class="bi bi-plus-circle-fill me-2"></i>Add First Destination
            </a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="section-title mb-0">Featured Destination Cards</h4>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="destination-card d-flex flex-column">
                        <div class="card-top">
                            <div class="destination-badge">
                                <i class="bi bi-globe-central-south-asia"></i>
                                Travel Spot
                            </div>

                            <div class="destination-title">@item.CityName</div>

                            <div class="destination-country">
                                <i class="bi bi-geo-alt-fill"></i>
                                <span>@item.Country</span>
                            </div>

                            <div class="destination-description">
                                @(string.IsNullOrWhiteSpace(item.Description)
                                    ? "No description available for this destination yet."
                                    : item.Description.Length > 120
                                        ? item.Description.Substring(0, 120) + "..."
                                        : item.Description)
                            </div>
                        </div>

                        <div class="info-panel">
                            <div class="rating-row mb-3">
                                <div class="rating-label">Traveler Rating</div>
                                <div class="stars">
                                    @{
                                        decimal rating = item.Rating;
                                        var fullStars = Math.Floor(rating);
                                    }

                                    @for (int i = 0; i < (int)fullStars; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }

                                    @for (int i = (int)fullStars; i < 5; i++)
                                    {
                                        <i class="bi bi-star"></i>
                                    }

                                    <span class="rating-number">@rating.ToString("0.0")</span>
                                </div>
                            </div>

                            <div class="date-row">
                                <div class="date-label">Last Visited</div>
                                <div class="date-value">@item.LastVisited.ToString("dd MMM yyyy")</div>
                            </div>
                        </div>

                        <div class="card-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-btn action-details">
                                <i class="bi bi-eye-fill me-1"></i>Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn action-edit">
                                <i class="bi bi-pencil-square me-1"></i>Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn action-delete">
                                <i class="bi bi-trash-fill me-1"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    const toggleBtn = document.getElementById("themeToggle");

    function applyTheme(mode) {
        if (mode === "pink") {
            document.body.classList.add("pink-mode");
            if (toggleBtn) {
                toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-2"></i>Theme';
            }
        } else {
            document.body.classList.remove("pink-mode");
            if (toggleBtn) {
                toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-2"></i>Theme';
            }
        }
    }

    const savedTheme = localStorage.getItem("theme") || "light";
    applyTheme(savedTheme);

    if (toggleBtn) {
        toggleBtn.addEventListener("click", function () {
            const newTheme = document.body.classList.contains("pink-mode") ? "light" : "pink";
            localStorage.setItem("theme", newTheme);
            applyTheme(newTheme);
        });
    }
</script>