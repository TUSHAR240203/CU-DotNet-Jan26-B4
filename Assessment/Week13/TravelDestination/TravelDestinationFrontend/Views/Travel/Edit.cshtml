@model TravelDestinationFrontend.Models.DestinationViewModel

@{
    ViewData["Title"] = "Edit Destination";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    :root {
        --bg-main: linear-gradient(135deg, #f8fbff 0%, #eef4ff 100%);
        --card-bg: rgba(255, 255, 255, 0.78);
        --card-border: rgba(255, 255, 255, 0.35);
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 20px 40px rgba(245, 158, 11, 0.18);
        --primary-grad: linear-gradient(135deg, #2563eb, #4f46e5);
        --accent-grad: linear-gradient(135deg, #f59e0b, #ea580c);
        --input-bg: rgba(255,255,255,0.65);
    }

    body.dark-mode {
        --bg-main: linear-gradient(135deg, #0f172a 0%, #111827 50%, #1e293b 100%);
        --card-bg: rgba(17, 24, 39, 0.76);
        --card-border: rgba(255, 255, 255, 0.08);
        --text-main: #f3f4f6;
        --text-muted: #9ca3af;
        --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.35);
        --shadow-hover: 0 20px 40px rgba(245, 158, 11, 0.22);
        --input-bg: rgba(255,255,255,0.04);
    }
    body.pink-mode {
    --bg-main: linear-gradient(135deg, #fff1f7 0%, #ffe4ee 50%, #ffd6e7 100%);
    --card-bg: rgba(255, 255, 255, 0.72);
    --card-border: rgba(255, 192, 203, 0.35);
    --text-main: #5b2146;
    --text-muted: #9a5f7d;
    --shadow-soft: 0 10px 30px rgba(236, 72, 153, 0.12);
    --shadow-hover: 0 20px 40px rgba(236, 72, 153, 0.20);
    --primary-grad: linear-gradient(135deg, #f9a8d4, #f472b6);
    --accent-grad: linear-gradient(135deg, #fbcfe8, #f9a8d4);
    --input-bg: rgba(255,255,255,0.75);
}
    body {
        background: var(--bg-main);
        color: var(--text-main);
        transition: all 0.35s ease;
    }

    .edit-page {
        min-height: 100vh;
    }

    .hero-panel {
        position: relative;
        overflow: hidden;
        background: var(--primary-grad);
        border-radius: 28px;
        padding: 2rem;
        color: white;
        box-shadow: var(--shadow-soft);
        margin-bottom: 1.5rem;
    }

        .hero-panel::before,
        .hero-panel::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
        }

        .hero-panel::before {
            width: 220px;
            height: 220px;
            top: -70px;
            right: -60px;
        }

        .hero-panel::after {
            width: 130px;
            height: 130px;
            bottom: -40px;
            left: 25%;
        }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.4rem;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.88);
        margin-bottom: 0;
    }

    .top-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn-modern {
        border: none;
        border-radius: 14px;
        padding: 0.8rem 1.15rem;
        font-weight: 700;
        transition: all 0.25s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-theme {
        background: rgba(255,255,255,0.16);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        backdrop-filter: blur(12px);
    }

        .btn-theme:hover {
            background: rgba(255,255,255,0.24);
            color: white;
            transform: translateY(-2px);
        }

    .btn-back-top {
        background: white;
        color: #1d4ed8;
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
    }

        .btn-back-top:hover {
            color: #1e40af;
            transform: translateY(-2px);
        }

    .form-shell {
        background: var(--card-bg);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid var(--card-border);
        border-radius: 28px;
        box-shadow: var(--shadow-soft);
        overflow: hidden;
    }

    .form-shell-header {
        background: var(--accent-grad);
        color: white;
        padding: 1.25rem 1.5rem;
    }

        .form-shell-header h3 {
            margin: 0;
            font-weight: 800;
        }

        .form-shell-header p {
            margin: 0.35rem 0 0;
            color: rgba(255,255,255,0.88);
        }

    .form-shell-body {
        padding: 1.75rem;
    }

    .destination-preview {
        background: rgba(255,255,255,0.28);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 22px;
        padding: 1.2rem;
        margin-bottom: 1.4rem;
    }

    body.dark-mode .destination-preview {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .preview-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.12);
        color: #b45309;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 0.9rem;
    }

    body.dark-mode .preview-badge {
        background: rgba(251, 191, 36, 0.16);
        color: #fcd34d;
    }

    .preview-title {
        font-size: 1.35rem;
        font-weight: 800;
        margin-bottom: 0.2rem;
    }

    .preview-subtitle {
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 0;
    }

    .form-section-title {
        font-size: 1rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: var(--text-main);
    }

    .form-group-modern {
        margin-bottom: 1.25rem;
    }

    .form-label-modern {
        font-weight: 700;
        margin-bottom: 0.55rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-main);
    }

    .form-control-modern {
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, 0.25);
        background: var(--input-bg);
        color: var(--text-main);
        padding: 0.9rem 1rem;
        min-height: 54px;
        transition: all 0.25s ease;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);
    }

        .form-control-modern:focus {
            background: var(--input-bg);
            color: var(--text-main);
            border-color: rgba(245, 158, 11, 0.45);
            box-shadow: 0 0 0 0.2rem rgba(245, 158, 11, 0.14);
        }

    textarea.form-control-modern {
        min-height: 130px;
        resize: none;
    }

    .input-hint {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-top: 0.35rem;
    }

    .validation-summary-modern {
        border-radius: 18px;
        padding: 1rem 1.1rem;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.18);
        margin-bottom: 1.25rem;
    }

    .field-validation-error,
    .text-danger {
        font-size: 0.88rem;
    }

    .action-row {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .btn-update {
        background: var(--accent-grad);
        color: white;
        box-shadow: 0 12px 24px rgba(245, 158, 11, 0.2);
        min-width: 170px;
    }

        .btn-update:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 16px 28px rgba(245, 158, 11, 0.26);
        }

    .btn-back {
        background: rgba(148, 163, 184, 0.14);
        color: var(--text-main);
        border: 1px solid rgba(148, 163, 184, 0.18);
        min-width: 150px;
    }

        .btn-back:hover {
            color: var(--text-main);
            transform: translateY(-2px);
        }

    .side-panel {
        background: var(--card-bg);
        backdrop-filter: blur(18px);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        box-shadow: var(--shadow-soft);
        padding: 1.4rem;
        height: 100%;
    }

    .side-icon-box {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-grad);
        color: white;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .side-title {
        font-weight: 800;
        margin-bottom: 0.55rem;
    }

    .side-text {
        color: var(--text-muted);
        line-height: 1.7;
        font-size: 0.94rem;
        margin-bottom: 0;
    }

    .tip-list {
        padding-left: 1rem;
        margin-bottom: 0;
        color: var(--text-muted);
    }

        .tip-list li {
            margin-bottom: 0.55rem;
        }

    body.dark-mode .form-control-modern::placeholder {
        color: #94a3b8;
    }

    @@media (max-width: 991px) {
        .hero-title {
            font-size: 1.6rem;
        }

        .form-shell-body {
            padding: 1.2rem;
        }
    }
</style>

<div class="container py-4 edit-page">
    <div class="hero-panel">
        <div class="hero-content">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="hero-title">✏️ Edit Destination</div>
                    <p class="hero-subtitle">
                        Update your destination information with the same premium editing experience.
                    </p>
                </div>

                <div class="top-actions">
                    <button id="themeToggle" type="button" class="btn-modern btn-theme">
                        <i class="bi bi-moon-stars-fill me-2"></i>Theme
                    </button>

                    <a asp-action="Index" class="btn-modern btn-back-top">
                        <i class="bi bi-arrow-left-circle-fill me-2"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="form-shell">
                <div class="form-shell-header">
                    <h3><i class="bi bi-pencil-square me-2"></i>Edit Destination Details</h3>
                    <p>Refine and manage your saved travel destination information.</p>
                </div>

                <div class="form-shell-body">
                    <div class="destination-preview">
                        <div class="preview-badge">
                            <i class="bi bi-stars"></i>
                            Editing Record
                        </div>

                        <div class="preview-title">@Model.CityName</div>
                        <div class="preview-subtitle">
                            <i class="bi bi-geo-alt-fill"></i>
                            <span>@Model.Country</span>
                        </div>
                    </div>

                    <form asp-action="Edit" method="post">
                        <input asp-for="Id" type="hidden" />
                        <div asp-validation-summary="All" class="text-danger validation-summary-modern"></div>

                        <div class="form-section-title">Update Information</div>

                        <div class="form-group-modern">
                            <label asp-for="CityName" class="form-label-modern">
                                <i class="bi bi-buildings"></i> City Name
                            </label>
                            <input asp-for="CityName" class="form-control form-control-modern" placeholder="Enter city name" />
                            <div class="input-hint">Use a clean and consistent city name.</div>
                            <span asp-validation-for="CityName" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Country" class="form-label-modern">
                                <i class="bi bi-geo-alt-fill"></i> Country
                            </label>
                            <input asp-for="Country" class="form-control form-control-modern" placeholder="Enter country name" />
                            <div class="input-hint">Keep the country value clear and accurate.</div>
                            <span asp-validation-for="Country" class="text-danger"></span>
                        </div>

                        <div class="form-group-modern">
                            <label asp-for="Description" class="form-label-modern">
                                <i class="bi bi-card-text"></i> Description
                            </label>
                            <textarea asp-for="Description" class="form-control form-control-modern" placeholder="Update the destination description"></textarea>
                            <div class="input-hint">Refresh the description to improve clarity and presentation.</div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="Rating" class="form-label-modern">
                                        <i class="bi bi-star-fill"></i> Rating
                                    </label>
                                    <input asp-for="Rating" class="form-control form-control-modern" placeholder="Enter rating" />
                                    <div class="input-hint">Use a value such as 4.5 or 5.0.</div>
                                    <span asp-validation-for="Rating" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group-modern">
                                    <label asp-for="LastVisited" class="form-label-modern">
                                        <i class="bi bi-calendar-check-fill"></i> Last Visited
                                    </label>
                                    <input asp-for="LastVisited" class="form-control form-control-modern" type="date" />
                                    <div class="input-hint">Update the latest visit date if needed.</div>
                                    <span asp-validation-for="LastVisited" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="action-row">
                            <button type="submit" class="btn-modern btn-update">
                                <i class="bi bi-check-circle-fill me-2"></i>Update Destination
                            </button>

                            <a asp-action="Index" class="btn-modern btn-back">
                                <i class="bi bi-arrow-left me-2"></i>Back
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="side-panel mb-4">
                <div class="side-icon-box">
                    <i class="bi bi-compass-fill"></i>
                </div>
                <div class="side-title">Advanced Editing Experience</div>
                <p class="side-text">
                    This page matches your premium dashboard design and keeps editing smooth, modern, and visually impressive.
                </p>
            </div>

            <div class="side-panel">
                <div class="side-icon-box">
                    <i class="bi bi-lightbulb-fill"></i>
                </div>
                <div class="side-title">Editing Tips</div>
                <ul class="tip-list">
                    <li>Keep city and country names consistent across records.</li>
                    <li>Use concise descriptions for a cleaner card layout.</li>
                    <li>Enter realistic ratings for better display quality.</li>
                    <li>Update dates carefully to keep travel history accurate.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const toggleBtn = document.getElementById("themeToggle");

        function applyTheme(mode) {
            if (mode === "pink") {
                document.body.classList.add("pink-mode");
                if (toggleBtn) {
                    toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-2"></i>Theme';
                }
            } else {
                document.body.classList.remove("pink-mode");
                if (toggleBtn) {
                    toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-2"></i>Theme';
                }
            }
        }

        const savedTheme = localStorage.getItem("theme") || "light";
        applyTheme(savedTheme);

        if (toggleBtn) {
            toggleBtn.addEventListener("click", function () {
                const newTheme = document.body.classList.contains("pink-mode") ? "light" : "pink";
                localStorage.setItem("theme", newTheme);
                applyTheme(newTheme);
            });
        }
    </script>
}