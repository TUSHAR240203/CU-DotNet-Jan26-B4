@model TravelDestinationFrontend.Models.DestinationViewModel

@{
    ViewData["Title"] = "Delete Destination";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    :root {
        --bg-main: linear-gradient(135deg, #f8fbff 0%, #eef4ff 100%);
        --card-bg: rgba(255, 255, 255, 0.78);
        --card-border: rgba(255, 255, 255, 0.35);
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.08);
        --shadow-hover: 0 18px 38px rgba(239, 68, 68, 0.18);
        --primary-grad: linear-gradient(135deg, #2563eb, #4f46e5);
        --danger-grad: linear-gradient(135deg, #ef4444, #dc2626);
        --danger-soft: rgba(239, 68, 68, 0.08);
        --danger-border: rgba(239, 68, 68, 0.16);
    }

    body.dark-mode {
        --bg-main: linear-gradient(135deg, #0f172a 0%, #111827 50%, #1e293b 100%);
        --card-bg: rgba(17, 24, 39, 0.76);
        --card-border: rgba(255, 255, 255, 0.08);
        --text-main: #f3f4f6;
        --text-muted: #9ca3af;
        --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.35);
        --shadow-hover: 0 20px 40px rgba(239, 68, 68, 0.22);
        --danger-soft: rgba(239, 68, 68, 0.12);
        --danger-border: rgba(239, 68, 68, 0.2);
    }
    body.pink-mode {
    --bg-main: linear-gradient(135deg, #fff1f7 0%, #ffe4ee 50%, #ffd6e7 100%);
    --card-bg: rgba(255, 255, 255, 0.72);
    --card-border: rgba(255, 192, 203, 0.35);
    --text-main: #5b2146;
    --text-muted: #9a5f7d;
    --shadow-soft: 0 10px 30px rgba(236, 72, 153, 0.12);
    --shadow-hover: 0 20px 40px rgba(236, 72, 153, 0.20);
    --primary-grad: linear-gradient(135deg, #f9a8d4, #f472b6);
    --accent-grad: linear-gradient(135deg, #fbcfe8, #f9a8d4);
    --input-bg: rgba(255,255,255,0.75);
}
    body {
        background: var(--bg-main);
        color: var(--text-main);
        transition: all 0.35s ease;
    }

    .delete-page {
        min-height: 100vh;
    }

    .hero-panel {
        position: relative;
        overflow: hidden;
        background: var(--primary-grad);
        border-radius: 28px;
        padding: 2rem;
        color: white;
        box-shadow: var(--shadow-soft);
        margin-bottom: 1.5rem;
    }

        .hero-panel::before,
        .hero-panel::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            background: rgba(255,255,255,0.12);
        }

        .hero-panel::before {
            width: 220px;
            height: 220px;
            top: -70px;
            right: -60px;
        }

        .hero-panel::after {
            width: 130px;
            height: 130px;
            bottom: -40px;
            left: 28%;
        }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .hero-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 0.4rem;
    }

    .hero-subtitle {
        color: rgba(255,255,255,0.88);
        margin-bottom: 0;
    }

    .top-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .btn-modern {
        border: none;
        border-radius: 14px;
        padding: 0.8rem 1.15rem;
        font-weight: 700;
        transition: all 0.25s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-theme {
        background: rgba(255,255,255,0.16);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        backdrop-filter: blur(12px);
    }

        .btn-theme:hover {
            background: rgba(255,255,255,0.24);
            color: white;
            transform: translateY(-2px);
        }

    .btn-back-top {
        background: white;
        color: #1d4ed8;
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
    }

        .btn-back-top:hover {
            color: #1e40af;
            transform: translateY(-2px);
        }

    .warning-panel {
        background: var(--danger-soft);
        border: 1px solid var(--danger-border);
        border-radius: 22px;
        padding: 1.25rem 1.4rem;
        box-shadow: var(--shadow-soft);
        margin-bottom: 1.4rem;
        display: flex;
        align-items: start;
        gap: 1rem;
    }

    .warning-icon {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        background: var(--danger-grad);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        flex-shrink: 0;
    }

    .warning-title {
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .warning-text {
        color: var(--text-muted);
        margin-bottom: 0;
        line-height: 1.6;
    }

    .details-card {
        background: var(--card-bg);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid var(--card-border);
        border-radius: 28px;
        box-shadow: var(--shadow-soft);
        overflow: hidden;
    }

    .details-header {
        background: var(--danger-grad);
        color: white;
        padding: 1.25rem 1.5rem;
    }

        .details-header h3 {
            margin: 0;
            font-weight: 800;
        }

        .details-header p {
            margin: 0.35rem 0 0;
            color: rgba(255,255,255,0.88);
        }

    .details-body {
        padding: 1.6rem;
    }

    .destination-preview {
        background: rgba(255,255,255,0.3);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 22px;
        padding: 1.25rem;
        margin-bottom: 1.2rem;
    }

    body.dark-mode .destination-preview {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .destination-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 0.9rem;
    }

    body.dark-mode .destination-badge {
        background: rgba(248, 113, 113, 0.16);
        color: #fca5a5;
    }

    .destination-title {
        font-size: 1.45rem;
        font-weight: 800;
        margin-bottom: 0.25rem;
    }

    .destination-subtitle {
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 0;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .info-item {
        background: rgba(255,255,255,0.28);
        border: 1px solid rgba(255,255,255,0.16);
        border-radius: 18px;
        padding: 1rem 1rem;
        min-height: 100%;
    }

    body.dark-mode .info-item {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
    }

    .info-label {
        color: var(--text-muted);
        font-size: 0.84rem;
        font-weight: 700;
        margin-bottom: 0.45rem;
        display: flex;
        align-items: center;
        gap: 0.45rem;
    }

    .info-value {
        color: var(--text-main);
        font-weight: 700;
        line-height: 1.65;
        word-break: break-word;
    }

    .description-box {
        grid-column: 1 / -1;
    }

    .rating-stars {
        display: flex;
        align-items: center;
        gap: 0.2rem;
        flex-wrap: wrap;
    }

        .rating-stars i {
            color: #fbbf24;
            font-size: 0.96rem;
        }

    .rating-number {
        margin-left: 0.4rem;
        font-weight: 800;
    }

    .action-bar {
        margin-top: 1.5rem;
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
    }

    .btn-delete {
        background: var(--danger-grad);
        color: white;
        box-shadow: 0 12px 24px rgba(239, 68, 68, 0.2);
        min-width: 180px;
    }

        .btn-delete:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 16px 28px rgba(239, 68, 68, 0.26);
        }

    .btn-cancel {
        background: rgba(148, 163, 184, 0.14);
        color: var(--text-main);
        border: 1px solid rgba(148, 163, 184, 0.18);
        min-width: 160px;
    }

        .btn-cancel:hover {
            color: var(--text-main);
            transform: translateY(-2px);
        }

    .side-panel {
        background: var(--card-bg);
        backdrop-filter: blur(18px);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        box-shadow: var(--shadow-soft);
        padding: 1.4rem;
        height: 100%;
    }

    .side-icon-box {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--danger-grad);
        color: white;
        font-size: 1.4rem;
        margin-bottom: 1rem;
    }

    .side-title {
        font-weight: 800;
        margin-bottom: 0.55rem;
    }

    .side-text {
        color: var(--text-muted);
        line-height: 1.7;
        font-size: 0.94rem;
        margin-bottom: 0;
    }

    .tip-list {
        padding-left: 1rem;
        margin-bottom: 0;
        color: var(--text-muted);
    }

        .tip-list li {
            margin-bottom: 0.55rem;
        }

    @@media (max-width: 767px) {
        .hero-title {
            font-size: 1.6rem;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="container py-4 delete-page">
    <div class="hero-panel">
        <div class="hero-content">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="hero-title">🗑️ Delete Destination</div>
                    <p class="hero-subtitle">
                        Review the destination details carefully before removing it from your travel collection.
                    </p>
                </div>

                <div class="top-actions">
                    <button id="themeToggle" type="button" class="btn-modern btn-theme">
                        <i class="bi bi-moon-stars-fill me-2"></i>Theme
                    </button>

                    <a asp-action="Index" class="btn-modern btn-back-top">
                        <i class="bi bi-arrow-left-circle-fill me-2"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="warning-panel">
                <div class="warning-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div>
                    <div class="warning-title">Are you sure you want to delete this destination?</div>
                    <p class="warning-text">
                        This action is intended to permanently remove the selected destination record from your interface.
                        Please confirm the information below before continuing.
                    </p>
                </div>
            </div>

            <div class="details-card">
                <div class="details-header">
                    <h3><i class="bi bi-trash3-fill me-2"></i>Deletion Preview</h3>
                    <p>Destination information that will be removed from your travel dashboard.</p>
                </div>

                <div class="details-body">
                    <div class="destination-preview">
                        <div class="destination-badge">
                            <i class="bi bi-shield-exclamation"></i>
                            Pending Deletion
                        </div>

                        <div class="destination-title">@Model.CityName</div>

                        <div class="destination-subtitle">
                            <i class="bi bi-geo-alt-fill"></i>
                            <span>@Model.Country</span>
                        </div>
                    </div>

                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">
                                <i class="bi bi-buildings"></i> City Name
                            </div>
                            <div class="info-value">@Model.CityName</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="bi bi-globe-central-south-asia"></i> Country
                            </div>
                            <div class="info-value">@Model.Country</div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="bi bi-star-fill"></i> Rating
                            </div>
                            <div class="info-value">
                                <div class="rating-stars">
                                    @{
                                        decimal rating = Model.Rating;
                                        var fullStars = Math.Floor(rating);
                                    }

                                    @for (int i = 0; i < (int)fullStars; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }

                                    @for (int i = (int)fullStars; i < 5; i++)
                                    {
                                        <i class="bi bi-star"></i>
                                    }

                                    <span class="rating-number">@rating.ToString("0.0")</span>
                                </div>
                            </div>
                        </div>

                        <div class="info-item">
                            <div class="info-label">
                                <i class="bi bi-calendar-check-fill"></i> Last Visited
                            </div>
                            <div class="info-value">@Model.LastVisited.ToString("dd MMM yyyy")</div>
                        </div>

                        <div class="info-item description-box">
                            <div class="info-label">
                                <i class="bi bi-card-text"></i> Description
                            </div>
                            <div class="info-value">
                                @(string.IsNullOrWhiteSpace(Model.Description)
                                    ? "No description available for this destination."
                                    : Model.Description)
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input asp-for="Id" type="hidden" />

                        <div class="action-bar">
                            <button type="submit" class="btn-modern btn-delete">
                                <i class="bi bi-trash-fill me-2"></i>Delete Destination
                            </button>

                            <a asp-action="Index" class="btn-modern btn-cancel">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="side-panel mb-4">
                <div class="side-icon-box">
                    <i class="bi bi-exclamation-octagon-fill"></i>
                </div>
                <div class="side-title">Deletion Confirmation</div>
                <p class="side-text">
                    This view is designed to make destructive actions feel deliberate, clear, and professional with a premium confirmation interface.
                </p>
            </div>

            <div class="side-panel">
                <div class="side-icon-box">
                    <i class="bi bi-info-circle-fill"></i>
                </div>
                <div class="side-title">Before You Continue</div>
                <ul class="tip-list">
                    <li>Make sure this is the correct destination record.</li>
                    <li>Review the city, country, and travel details carefully.</li>
                    <li>Use cancel if you want to keep the destination in your collection.</li>
                    <li>Only confirm deletion when you are fully sure.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
<script>
    const toggleBtn = document.getElementById("themeToggle");

    function applyTheme(mode) {
        if (mode === "pink") {
            document.body.classList.add("pink-mode");
            if (toggleBtn) {
                toggleBtn.innerHTML = '<i class="bi bi-sun-fill me-2"></i>Theme';
            }
        } else {
            document.body.classList.remove("pink-mode");
            if (toggleBtn) {
                toggleBtn.innerHTML = '<i class="bi bi-moon-stars-fill me-2"></i>Theme';
            }
        }
    }

    const savedTheme = localStorage.getItem("theme") || "light";
    applyTheme(savedTheme);

    if (toggleBtn) {
        toggleBtn.addEventListener("click", function () {
            const newTheme = document.body.classList.contains("pink-mode") ? "light" : "pink";
            localStorage.setItem("theme", newTheme);
            applyTheme(newTheme);
        });
    }
</script>