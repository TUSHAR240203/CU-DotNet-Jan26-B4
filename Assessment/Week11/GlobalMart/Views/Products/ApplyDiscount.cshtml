@model GlobalMart.Models.ApplyDiscountViewModel

@{
    ViewData["Title"] = "Apply Discount";
}

<h2>Apply Discount</h2>

<form asp-action="ApplyDiscount" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Product Name</label>
        <input asp-for="Name" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label class="form-label">Base Price</label>
        <input asp-for="Price" class="form-control" readonly />
    </div>

    <div class="mb-3">
        <label asp-for="PromoCode" class="form-label">Promo Code</label>
        <select asp-for="PromoCode" asp-items="Model.PromoCodes" class="form-select"></select>
    </div>

    <button type="submit" class="btn btn-primary">Apply</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>