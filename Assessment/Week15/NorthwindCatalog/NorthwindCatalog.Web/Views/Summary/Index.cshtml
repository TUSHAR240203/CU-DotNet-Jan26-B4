@model List<CategorySummaryDto>

@{
    ViewData["Title"] = "Summary";
}

<div class="container page-wrap">
    <div class="hero-glass mb-5">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
            <div>
                <span class="inventory-badge mb-3">Total Summaries: @(Model?.Count ?? 0)</span>
                <h1 class="hero-title mt-3">Category Analytics Summary</h1>
                <p class="hero-text">
                    Review category-wise product count, average price, and the most expensive product in a clean premium dashboard.
                </p>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Categories" asp-action="Index" class="glass-btn-outline">Back to Categories</a>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="glass-table-wrap">
            <div class="table-responsive">
                <table class="table glass-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Category Name</th>
                            <th>Product Count</th>
                            <th>Average Price</th>
                            <th>Most Expensive Product</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.CategoryName</div>
                                </td>
                                <td>
                                    <span class="summary-pill">@item.ProductCount</span>
                                </td>
                                <td>
                                    <span class="price-text">@item.AvgPrice.ToString("0.00")</span>
                                </td>
                                <td>
                                    <span class="product-highlight">@item.MostExpensiveProduct</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="empty-glass">No summary data found.</div>
    }
</div>