@{
    ViewData["Title"] = "Home";
}

<div class="p-5 mb-4 bg-primary text-white rounded-3">
    <div class="container-fluid py-4">

        <h1 class="display-5 fw-bold">Welcome to CompanyPortal</h1>

        <p class="col-md-8 fs-5">
            We provide simple business solutions, training, and useful software tools for modern companies.
        </p>

        <a asp-controller="Services" asp-action="Index" class="btn btn-success btn-lg me-2">
            Explore Services
        </a>

        <button class="btn btn-success btn-lg" onclick="showToast()">
            Show Message
        </button>

    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Consulting</h5>
                <p class="card-text">Professional guidance to improve business growth and planning.</p>
                <a asp-controller="Services" asp-action="Consulting" class="btn btn-primary">Read More</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Training</h5>
                <p class="card-text">Skill-based workshops for students, teams, and working professionals.</p>
                <a asp-controller="Services" asp-action="Training" class="btn btn-primary">Read More</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="card-text">Reliable digital products and software tools for everyday business needs.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">View Products</a>
            </div>
        </div>
    </div>
</div>


<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
    <div id="myToast" class="toast align-items-center text-bg-success border-0">
        <div class="d-flex">
            <div class="toast-body">
                Welcome to CompanyPortal 🚀
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<script>
    function showToast() {

        var toastElement = document.getElementById("myToast")

        var toast = new bootstrap.Toast(toastElement)

        toast.show()

    }
</script>       