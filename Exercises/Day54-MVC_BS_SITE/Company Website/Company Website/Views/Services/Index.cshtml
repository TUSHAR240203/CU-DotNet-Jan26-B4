@{
    ViewData["Title"] = "Services";
}

<h2 class="mb-4">Our Services</h2>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card border-primary h-100">
            <div class="card-body">
                <h5 class="card-title">Business Consulting</h5>
                <p class="card-text">We help organizations improve planning, strategy, and execution.</p>
                <a asp-controller="Services" asp-action="Consulting" class="btn btn-primary">View Consulting</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card border-success h-100">
            <div class="card-body">
                <h5 class="card-title">Corporate Training</h5>
                <p class="card-text">Interactive sessions and technical workshops for teams and freshers.</p>
                <a asp-controller="Services" asp-action="Training" class="btn btn-success">View Training</a>
            </div>
        </div>
    </div>
</div>