@{
    ViewData["Title"] = "Consulting";
}

<h2 class="mb-4">Consulting Services</h2>

<div class="accordion" id="consultingAccordion">
    <div class="accordion-item">
        <h2 class="accordion-header" id="headingOne">
            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                Business Strategy
            </button>
        </h2>
        <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#consultingAccordion">
            <div class="accordion-body">
                We guide companies in setting clear goals and long-term strategies.
            </div>
        </div>
    </div>

    <div class="accordion-item">
        <h2 class="accordion-header" id="headingTwo">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">
                Market Analysis
            </button>
        </h2>
        <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#consultingAccordion">
            <div class="accordion-body">
                We provide insights about market trends, competitors, and customer expectations.
            </div>
        </div>
    </div>

    <div class="accordion-item">
        <h2 class="accordion-header" id="headingThree">
            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">
                Process Improvement
            </button>
        </h2>
        <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#consultingAccordion">
            <div class="accordion-body">
                We improve workflow efficiency and reduce unnecessary delays in operations.
            </div>
        </div>
    </div>
</div>