@model SmartBankFrontend.DTOs.Loan.ApplyLoanDto

@{
    ViewData["Title"] = "Apply Loan";
}

<div class="container mt-4">
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="fw-bold mb-4">Apply for Loan</h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-action="Apply" method="post">
                <div class="mb-3">
                    <label class="form-label">Requested Amount</label>
                    <input asp-for="RequestedAmount" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tenure (Months)</label>
                    <input asp-for="TenureMonths" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Annual Interest Rate</label>
                    <input asp-for="AnnualInterestRate" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Purpose</label>
                    <input asp-for="Purpose" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Monthly Income</label>
                    <input asp-for="MonthlyIncome" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Employment Status</label>
                    <select asp-for="EmploymentStatus" class="form-select">
                        <option value="">Select</option>
                        <option>Salaried</option>
                        <option>Self-Employed</option>
                        <option>Business</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Submit Loan Request</button>
                <a asp-action="MyApplications" class="btn btn-outline-secondary ms-2">My Applications</a>
            </form>
        </div>
    </div>
</div>