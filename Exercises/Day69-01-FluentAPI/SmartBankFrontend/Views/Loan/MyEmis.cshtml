@model List<SmartBankFrontend.DTOs.Loan.LoanEmiDto>

@{
    ViewData["Title"] = "My EMIs";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4">My EMI Schedule</h2>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Loan ID</th>
                        <th>Installment</th>
                        <th>Due Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Paid On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.LoanId</td>
                            <td>@item.InstallmentNumber</td>
                            <td>@item.DueDate.ToString("dd-MM-yyyy")</td>
                            <td>@item.Amount</td>
                            <td>@item.PaymentStatus</td>
                            <td>@(item.PaidOn?.ToString("dd-MM-yyyy") ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>