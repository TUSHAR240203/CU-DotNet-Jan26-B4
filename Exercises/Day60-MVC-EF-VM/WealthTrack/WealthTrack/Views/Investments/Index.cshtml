@model IEnumerable<WealthTrack.Models.Investment>

@{
    ViewData["Title"] = "Portfolio";
}

<h2 class="mb-4 text-center">📊 My Investments</h2>

<div class="mb-3 text-end">
    <a asp-action="Create" class="btn btn-success">+ Add Investment</a>
</div>

<table class="table table-bordered table-hover table-striped shadow">
    <thead class="table-dark text-center">
        <tr>
            <th>Ticker</th>
            <th>Asset Name</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Date</th>
            <th>Total</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr class="text-center align-middle custom-row">
                <td>@item.TickerSymbol</td>
                <td>@item.AssetName</td>
                <td>₹ @item.PurchasePrice</td>
                <td>@item.Quantity</td>
                <td>@item.PurchaseDate.ToString("dd-MM-yyyy")</td>
                <td><strong>₹ @(item.PurchasePrice* item.Quantity)</strong></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .custom-row:hover {
        background-color: #f2f2f2;
        transform: scale(1.01);
        transition: 0.2s ease-in-out;
    }
</style>