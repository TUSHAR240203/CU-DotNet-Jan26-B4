@model WealthTrack.Models.Investment

@{
    ViewData["Title"] = "Edit Investment";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h3 class="mb-0">Edit Investment</h3>
        </div>

        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="TickerSymbol" class="form-label fw-semibold"></label>
                    <input asp-for="TickerSymbol" class="form-control custom-input" />
                    <span asp-validation-for="TickerSymbol" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AssetName" class="form-label fw-semibold"></label>
                    <input asp-for="AssetName" class="form-control custom-input" />
                    <span asp-validation-for="AssetName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PurchasePrice" class="form-label fw-semibold"></label>
                    <input asp-for="PurchasePrice" class="form-control custom-input" />
                    <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label fw-semibold"></label>
                    <input asp-for="Quantity" class="form-control custom-input" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PurchaseDate" class="form-label fw-semibold"></label>
                    <input asp-for="PurchaseDate" type="date" class="form-control custom-input" />
                    <span asp-validation-for="PurchaseDate" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <input type="submit" value="Save Changes" class="btn btn-primary px-4" />
                    <a asp-action="Index" class="btn btn-secondary px-4">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .custom-input {
        transition: 0.2s ease-in-out;
        border-radius: 10px;
    }

        .custom-input:hover {
            box-shadow: 0 0 8px rgba(13, 110, 253, 0.25);
            border-color: #0d6efd;
        }

    .card:hover {
        transform: scale(1.01);
        transition: 0.2s ease-in-out;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}