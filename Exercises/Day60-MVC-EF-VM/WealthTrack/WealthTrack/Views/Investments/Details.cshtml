@model WealthTrack.Models.Investment

@{
    ViewData["Title"] = "Investment Details";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">

        <!-- Header -->
        <div class="card-header bg-dark text-white rounded-top-4">
            <h3 class="mb-0">📊 Investment Details</h3>
        </div>

        <!-- Body -->
        <div class="card-body p-4">

            <div class="row mb-3 detail-row">
                <div class="col-4 fw-bold">Ticker Symbol</div>
                <div class="col-8">@Model.TickerSymbol</div>
            </div>

            <div class="row mb-3 detail-row">
                <div class="col-4 fw-bold">Asset Name</div>
                <div class="col-8">@Model.AssetName</div>
            </div>

            <div class="row mb-3 detail-row">
                <div class="col-4 fw-bold">Purchase Price</div>
                <div class="col-8">₹ @Model.PurchasePrice</div>
            </div>

            <div class="row mb-3 detail-row">
                <div class="col-4 fw-bold">Quantity</div>
                <div class="col-8">@Model.Quantity</div>
            </div>

            <div class="row mb-3 detail-row">
                <div class="col-4 fw-bold">Purchase Date</div>
                <div class="col-8">@Model.PurchaseDate.ToString("dd-MM-yyyy")</div>
            </div>

            <div class="row mb-3 detail-row bg-light p-2 rounded">
                <div class="col-4 fw-bold">Total Investment</div>
                <div class="col-8 fw-bold text-success">
                    ₹ @(Model.PurchasePrice* Model.Quantity)
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="card-footer text-end">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">Edit</a>
            <a asp-action="Index" class="btn btn-secondary px-4">Back</a>
        </div>

    </div>
</div>

<style>
    .detail-row {
        transition: 0.2s ease-in-out;
        padding: 8px;
        border-radius: 8px;
    }

        .detail-row:hover {
            background-color: #f1f1f1;
            transform: scale(1.01);
        }

    .card:hover {
        transform: scale(1.01);
        transition: 0.2s ease-in-out;
    }
</style>