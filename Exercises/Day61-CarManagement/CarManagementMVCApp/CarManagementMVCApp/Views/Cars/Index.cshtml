@model IEnumerable<CarManagementMVCApp.Models.Car>

@{
    ViewData["Title"] = "Cars";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">Car Collection</h1>
        <p class="text-muted mb-0">Manage and explore premium vehicles</p>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Customer"))
    {
        <a asp-action="Create" class="btn premium-btn">
            Add New Car
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-lg-4 col-md-6">
            <div class="car-card">
                <div class="car-card-top">
                    <div class="car-icon-wrap">
                        Car
                    </div>
                    <span class="year-badge">@item.Year</span>
                </div>

                <h3 class="car-title">@item.Brand @item.Model</h3>
                <p class="car-price">₹ @item.Price.ToString("N0")</p>

                <div class="car-actions">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm premium-btn-outline">Details</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm premium-btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm premium-btn-danger">Delete</a>
                    }
                </div>
            </div>
        </div>
    }
</div>