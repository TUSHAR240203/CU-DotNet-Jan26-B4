@model CarManagementMVCApp.Models.Car

@{
    ViewData["Title"] = "Delete Car";
}

<div class="form-wrapper">
    <div class="premium-card p-4 p-md-5">
        <h2 class="mb-4 text-danger">Delete Car</h2>
        <p class="mb-4">Are you sure you want to delete this car?</p>

        <div class="details-box mb-4">
            <p><strong>Brand:</strong> @Model.Brand</p>
            <p><strong>Model:</strong> @Model.Model</p>
            <p><strong>Year:</strong> @Model.Year</p>
            <p><strong>Price:</strong> ₹ @Model.Price.ToString("N0")</p>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-3">
                <button type="submit" class="btn premium-btn-danger">Delete</button>
                <a asp-action="Index" class="btn premium-btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>