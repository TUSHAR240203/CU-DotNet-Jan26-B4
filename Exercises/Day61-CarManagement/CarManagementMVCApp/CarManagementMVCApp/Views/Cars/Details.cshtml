@model CarManagementMVCApp.Models.Car

@{
    ViewData["Title"] = "Car Details";
}

<div class="form-wrapper">
    <div class="premium-card p-4 p-md-5">
        <div class="text-center mb-4">
            <div class="car-icon-large">
                <i class="bi bi-car-front-fill"></i>
            </div>
            <h2 class="mt-3">@Model.Brand @Model.Model</h2>
        </div>

        <div class="details-box">
            <p><strong>Brand:</strong> @Model.Brand</p>
            <p><strong>Model:</strong> @Model.Model</p>
            <p><strong>Year:</strong> @Model.Year</p>
            <p><strong>Price:</strong> ₹ @Model.Price.ToString("N0")</p>
        </div>

        <div class="mt-4 d-flex gap-3">
            <a asp-action="Index" class="btn premium-btn-outline">Back</a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn premium-btn-warning">Edit</a>
            }
        </div>
    </div>
</div>