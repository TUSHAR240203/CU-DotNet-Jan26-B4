@model IEnumerable<CarManagementMVCApp.Models.UserRoleViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="premium-card p-4 p-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">User Management</h2>
            <p class="text-muted mb-0">Admin can assign roles to users</p>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Current Role</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.Role</td>
                        <td>
                            <a asp-action="ManageRole" asp-route-id="@user.UserId" class="btn premium-btn-warning btn-sm">
                                Change Role
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>