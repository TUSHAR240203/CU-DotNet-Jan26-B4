@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="auth-page">
    <div class="auth-box">
        <div class="auth-left">
            <div>
                <div class="logo-circle mb-4">
                    <i class="bi bi-car-front-fill"></i>
                </div>
                <h1>AutoLux Motors</h1>
                <p class="mt-3">
                    Secure premium portal for car management with role-based access.
                </p>
            </div>
        </div>

        <div class="auth-right">
            <h2 class="mb-4">Welcome Back</h2>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control premium-input" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" class="form-control premium-input" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label"></label>
                </div>

                <button id="login-submit" type="submit" class="btn premium-btn w-100 mb-3">Login</button>

                <div class="text-center">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Create a new account</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}